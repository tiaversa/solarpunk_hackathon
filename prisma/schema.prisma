// Green Quest — Prisma schema.
// Models are added incrementally per /docs/PLAN.md; this file currently
// reflects the state after Step 6 (MVP COMPLETE). The `moddatetime`
// extension is enabled via a separate SQL migration so triggers can rely
// on it.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Runtime queries go through Supabase's Supavisor pooler in transaction
  // mode (port 6543, ?pgbouncer=true so Prisma disables prepared
  // statements).
  url       = env("DATABASE_URL")
  // Migrations bypass the pooler (direct connection, port 5432) because
  // Prisma migrate needs session-level state — advisory locks and
  // prepared statements — that transaction pooling can't preserve.
  directUrl = env("DIRECT_URL")
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  // passwordHash is NOT in the original spec (which said only "NextAuth (JWT)"
  // without specifying a provider). We chose the Credentials provider, which
  // requires a server-side hashed password. It is never returned to the client.
  passwordHash      String
  city              String?
  // latitude and longitude are reserved for future GPS support; the current
  // implementation uses server-side IP geolocation (Step 3).
  latitude          Float?
  longitude         Float?
  interests         String[] @default([])
  preferredDuration String? // 'short' | 'medium' | 'long'
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  progress          Progress[]
  aiGenerations     AiGeneration[]
  missionChoices    MissionChoice[]
  completions       Completion[]
  preferenceSummary UserPreferenceSummary?
}

model Progress {
  id              String   @id @default(uuid())
  userId          String
  topic           String
  currentLevel    Int      @default(1) // 1-6
  completedLevels Int[]    @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, topic])
  @@index([userId])
}

model AiGeneration {
  id                    String    @id @default(uuid())
  userId                String
  topic                 String
  level                 Int
  missionTypeLabel      String
  matrixCellText        String
  city                  String
  // promptSent / rawResponse are kept INLINE for rows generated when
  // cold storage is disabled (no CLOUDINARY_URL). When enabled, the
  // payloads are uploaded to Cloudinary as raw JSON files and the URL
  // is stored in *Url; the inline columns stay null. Reads should
  // prefer URL → fetch when present, otherwise fall back to inline.
  promptSent            String?
  promptSentUrl         String?
  promptVersion         String
  preferenceSummarySent String?
  model                 String
  rawResponse           Json?     @db.JsonB
  rawResponseUrl        String?
  parsedOptions         Json?     @db.JsonB
  optionsCount          Int       @default(3)
  inputTokens           Int?
  outputTokens          Int?
  latencyMs             Int?
  error                 String?
  status                String    @default("active") // 'active' | 'regenerated'
  startedAt             DateTime  @default(now())
  completedAt           DateTime?
  createdAt             DateTime  @default(now())

  user          User            @relation(fields: [userId], references: [id])
  missionChoice MissionChoice[]

  // Composite index covers the cache-lookup query in GET /api/mission:
  // WHERE userId, topic, level, status = 'active'
  @@index([userId, topic, level, status])
}

model MissionChoice {
  id               String   @id @default(uuid())
  userId           String
  topic            String
  level            Int
  aiGenerationId   String
  optionsPresented Json     @db.JsonB
  chosenIndex      Int // 0-2
  // Per-MissionChoice ranked subset of the city's cached places, picked
  // by Claude immediately after the choice is recorded. Lets each of
  // the 3 missions on a level surface different places when their
  // shapes call for different OSM categories (e.g. a "talk to a tailor"
  // mission boosts Tailor places, while a "visit a market" mission
  // boosts Marketplace places). Null when ranking was skipped — no
  // places in cache, Claude failed, the row predates this column, or
  // the caller was offline.
  rankedPlaces     Json?    @db.JsonB
  status           String   @default("active") // active | abandoned | completed
  chosenAt         DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  aiGeneration AiGeneration @relation(fields: [aiGenerationId], references: [id])

  // Composite index covers the lookup in POST /api/mission/choose and the
  // upsert check: WHERE userId, topic, level, status = 'active'. The
  // partial unique index (raw SQL in this step's migration) sits on top of
  // this and prevents concurrent double-inserts.
  @@index([userId, topic, level, status])
}

model UserPreferenceSummary {
  userId     String   @id
  summary    String
  basedOn    Int
  computedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  // Created in Step 5 (empty) so the triggers there have a target table.
  // Actual population of this table is Step 11 (stretch).
}

/// Cached Solarpunk-aligned places per (city, topic), looked up on-demand
/// when a user picks a mission and reused across all users in the same
/// city. Backed by OpenStreetMap (Nominatim for geocoding + Overpass for
/// tagged places). Stays valid until manually invalidated; `refreshedAt`
/// lets a future cron refresh stale rows without dropping them.
model CityResources {
  id          String   @id @default(uuid())
  // `city` is stored verbatim from User.city (trimmed). Normalising
  // ("Berlin" vs "Berlin, Germany") via Nominatim's canonical name is a
  // v2 improvement; for now duplicates are a minor cache-efficiency
  // hit, not a correctness issue.
  city        String
  topic       String
  // Center used for the Overpass `around:` query — handy for future
  // distance calculations or map rendering. Null only if Nominatim
  // returned no result and we cached an empty places list anyway.
  centerLat   Float?
  centerLon   Float?
  // Array of CityResourcePlace objects (see lib/cityResources.ts).
  places      Json     @db.JsonB
  // Empty results are valid (e.g. small city, sparse OSM coverage).
  // The count is denormalised here for cheap "did the lookup find
  // anything?" filtering without parsing the JSON column.
  placesCount Int      @default(0)
  // Captured to make A/B'ing OSM query tweaks easy: the same row from
  // last week's query set is still useful for display, but you can
  // detect "this row predates the cooking-tag expansion" by version.
  querySetVersion String
  // `@updatedAt` makes Prisma auto-bump this whenever the row is
  // updated (e.g. when stale data gets re-fetched from OSM). The
  // staleness threshold lives in lib/cityResources.ts as
  // CACHE_TTL_DAYS — rows older than that are treated as cache misses
  // and re-fetched on the next choose action.
  refreshedAt DateTime @default(now()) @updatedAt
  createdAt   DateTime @default(now())

  @@unique([city, topic])
  @@index([city])
}

model Completion {
  id                 String   @id @default(uuid())
  userId             String
  topic              String
  level              Int
  // aiGenerationId and chosenMissionIndex must either both be present
  // (normal completion) or both be null (edge case). Enforced in the API
  // layer; a DB check constraint (raw SQL in this step's migration)
  // catches anything that slips past.
  aiGenerationId     String?
  chosenMissionIndex Int? // 0-2
  // photoPath is the bucket-relative Supabase Storage key
  // (e.g. "{userId}/{uuid}.jpg"), NOT a URL. The display URL is
  // minted on read via a signed URL — see lib/supabase.ts.
  photoPath          String?
  note               String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, topic, level])
}
