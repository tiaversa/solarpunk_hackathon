# Copy to .env and fill in. .env is git-ignored.

# ---------------------------------------------------------------------------
# Database (Supabase Postgres)
# ---------------------------------------------------------------------------
# Get both URLs from your Supabase dashboard:
#   Settings → Database → Connection string
#
# - DATABASE_URL  → "Transaction" pooler, port 6543. Used by Prisma client
#   at runtime. The ?pgbouncer=true flag tells Prisma to disable prepared
#   statements (Supavisor's transaction mode can't preserve them).
# - DIRECT_URL    → "Direct connection", port 5432. Used ONLY by
#   `prisma migrate` because migrations need session-level state
#   (advisory locks, prepared statements) the pooler can't preserve.
#
# Replace [project-ref], [password], and [region] with the values from your
# Supabase project. The password is your database password (Settings →
# Database → Reset database password if you don't have it).

DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# NextAuth
# ---------------------------------------------------------------------------
# Generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Anthropic (Claude) — required from Step 4 onward.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ---------------------------------------------------------------------------
# Supabase Storage — required from Step 6 onward (mission completion photos).
# ---------------------------------------------------------------------------
# We use the signed-upload-URL pattern: the server mints a single-use
# token, the browser uploads directly to Supabase Storage. No Cloudinary,
# no base64-over-JSON, no Vercel body-size limit.
#
# See docs/STORAGE_SETUP.md for the one-time bucket setup (create a
# private "mission-photos" bucket and copy the keys below from
# dashboard → Settings → API).

# Project URL: https://<project-ref>.supabase.co (same project as DATABASE_URL).
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"

# Anon key — safe to ship to the browser. Used to consume signed upload tokens.
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi...your_anon_key"

# Service-role key — server-only. Mints signed upload URLs and signed
# read URLs. Treat as a secret; never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi...your_service_role_key"

SUPABASE_ACCESS_TOKEN="sbp_14cd...your_token"