# Copy to .env and fill in. .env is git-ignored.

# ---------------------------------------------------------------------------
# Database (Postgres)
# ---------------------------------------------------------------------------
# Runtime URL — used by Prisma client for every query. In local dev this
# points at PgBouncer (port 6432, transaction pooling, ?pgbouncer=true).
# In production paste a Prisma Accelerate URL OR a Railway pgbouncer URL.
DATABASE_URL="postgresql://solarpunk:solarpunk@localhost:6432/solarpunk?pgbouncer=true&connection_limit=1"

# Direct URL — used ONLY by `prisma migrate` (it needs session-level
# state PgBouncer's transaction mode can't preserve). Always points to
# Postgres itself (port 5432 in local dev, the raw Railway URL in prod).
DIRECT_URL="postgresql://solarpunk:solarpunk@localhost:5432/solarpunk?schema=public"

# ---------------------------------------------------------------------------
# NextAuth
# ---------------------------------------------------------------------------
# Generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Anthropic (Claude) — required from Step 4 onward.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ---------------------------------------------------------------------------
# Cloudinary — required from Step 6 onward (mission completion photos).
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
# ---------------------------------------------------------------------------
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
